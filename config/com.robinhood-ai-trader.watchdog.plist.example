<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.robinhood-ai-trader.watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Frameworks/Python.framework/Versions/3.13/bin/python3</string>
    <string>/Users/ge/Documents/AI trading agent/robinhood-ai-trader/scripts/watchdog_tick.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/ge/Documents/AI trading agent/robinhood-ai-trader</string>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>StandardOutPath</key>
  <string>/Users/ge/Documents/AI trading agent/robinhood-ai-trader/logs/watchdog.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/ge/Documents/AI trading agent/robinhood-ai-trader/logs/watchdog.stderr.log</string>
</dict>
</plist>
