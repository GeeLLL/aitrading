{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quote_trajectory.schema.json",
  "title": "Observed read-only option quote trajectory event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trajectory_id",
    "event_type",
    "policy_labels",
    "instrument_id",
    "underlying",
    "option_type",
    "strike",
    "expiration_date",
    "decision_time",
    "quote_received_at",
    "source_updated_at",
    "bid",
    "ask",
    "mark",
    "volume",
    "open_interest",
    "evidence_class"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "trajectory_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["CANDIDATE", "QUOTE", "HORIZON_CLOSE", "DATA_ERROR"]},
    "policy_labels": {
      "type": "array",
      "items": {"enum": ["BASE_25", "BASE_30", "AI_RANK_V1", "NEAR_MISS"]},
      "minItems": 1,
      "uniqueItems": true
    },
    "instrument_id": {"type": "string", "minLength": 1},
    "underlying": {"type": "string", "pattern": "^[A-Z.]{1,10}$"},
    "option_type": {"enum": ["call", "put"]},
    "strike": {"type": "number", "exclusiveMinimum": 0},
    "expiration_date": {"type": "string", "format": "date"},
    "decision_time": {"type": "string", "format": "date-time"},
    "quote_received_at": {"type": "string", "format": "date-time"},
    "source_updated_at": {"type": ["string", "null"], "format": "date-time"},
    "bid": {"type": ["number", "null"], "minimum": 0},
    "ask": {"type": ["number", "null"], "minimum": 0},
    "mark": {"type": ["number", "null"], "minimum": 0},
    "volume": {"type": ["integer", "null"], "minimum": 0},
    "open_interest": {"type": ["integer", "null"], "minimum": 0},
    "delta": {"type": ["number", "null"], "minimum": -1, "maximum": 1},
    "implied_volatility": {"type": ["number", "null"], "minimum": 0},
    "theta": {"type": ["number", "null"]},
    "target_horizon_minutes": {"type": ["integer", "null"], "minimum": 0},
    "rejection_reasons": {"type": "array", "items": {"type": "string"}},
    "evidence_class": {"const": "PILOT_OBSERVED_QUOTE_EXCLUDED_FROM_PERFORMANCE"}
  }
}
